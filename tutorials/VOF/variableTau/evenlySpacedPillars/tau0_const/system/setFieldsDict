FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultFieldValues
(
    volScalarFieldValue alpha.water 1
    volScalarFieldValue tau0 4e-3
);

tau0UpperBiofilm 4e-3;
tau0LowerBiofilm 4e-3;

regions
(
    boxToCell
    {
        box (-2.8e-6 -5 -0.001) (0.01 5 0.001);  // Define your rectangular box

        fieldValues
        (
            volScalarFieldValue alpha.water 0
        );
    }
);

