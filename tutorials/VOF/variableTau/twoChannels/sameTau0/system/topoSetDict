FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      topoSetDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

x_min 0.3e-3;
x_max 2.7e-3;
y_min 0.3e-3;
y_max 0.7e-3;
z_min 0;
z_max 1.0;

actions
(
    {
        name    boxCells;
        type    cellSet;
        action  new;
        source  boxToCell;
        sourceInfo
        {
            box ($x_min $y_min $z_min) ($x_max $y_max $z_max);
        }
    }
