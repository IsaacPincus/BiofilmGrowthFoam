FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultFieldValues
(
    volScalarFieldValue alpha.water 1
    volScalarFieldValue tau0 2e-3
);

tau0UpperBiofilm 4e-3;
tau0LowerBiofilm 4e-3;

regions
(
    // lower channel
    boxToCell
    {
        box (0.3e-3 0 -1.0e-3) (2.7e-3 0.125e-3 1.0e-3);  // Define your rectangular box

        fieldValues
        (
            volScalarFieldValue alpha.water 0
            volScalarFieldValue tau0    $tau0LowerBiofilm 
        );
    }

    boxToCell
    {
        box (0.3e-3 0.175e-3 -1.0e-3) (2.7e-3 0.3e-3 1.0e-3);  // Define your rectangular box

        fieldValues
        (
            volScalarFieldValue alpha.water 0
            volScalarFieldValue tau0    $tau0LowerBiofilm 
        );
    }

    // upper channel
    boxToCell
    {
        box (0.3e-3 0.7e-3 -1.0e-3) (2.7e-3 1.0e-3 1.0e-3);  // Define your rectangular box

        fieldValues
        (
            volScalarFieldValue alpha.water 0
            volScalarFieldValue tau0    $tau0UpperBiofilm 
        );
    }

    // boxToCell
