FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     biofilmYieldFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime 111601.8;

deltaT          1e-8;

writeControl    adjustableRunTime;

writeInterval 0.1;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   9;

runTimeModifiable yes;

adjustTimeStep  yes;

maxCo           0.4;
maxAlphaCo      0.2;

maxDeltaT       0.01;

libs
(
    "libHerschelBulkleySpatial.so"
);

