# ============================================================
#  .gitignore for an OpenFOAM solver / library repository
#  Keeps: source (solvers, libraries), tutorial case *setups*,
#         Allwmake/Allrun scripts, dictionaries.
#  Ignores: everything wmake builds and everything a run produces.
# ============================================================

# ----------------------------------------------------------------
#  wmake build artifacts
# ----------------------------------------------------------------
# Generated symlink-include folders
**/lnInclude/
# Per-platform compiled objects (this keeps Make/files and Make/options,
# which are source, and ignores Make/<platform>/ which is generated)
**/Make/*/
# Compiled objects / libraries / dependency files
*.o
*.so
*.a
*.dep
# Final build output, if it ever lands in-tree
platforms/

# ----------------------------------------------------------------
#  Case run output (generated when a tutorial is actually run)
# ----------------------------------------------------------------
# Numeric time-step directories.
#   The 0 / 0.orig / 0.org directories hold initial & boundary
#   conditions and ARE kept.
[1-9]*/
0.[0-9]*/
!0/
!0.orig/
!0.org/

# Parallel decomposition
processor*/

# Solver / utility logs
log
log.*
*.log
logs/

# Post-processing, sampling, conversion output
postProcessing/
VTK/
*.vtk
*.vtu

# ParaView marker files
*.foam
*.OpenFOAM

# Runtime-compiled code (codedFixedValue, codedFunctionObject, ...)
dynamicCode/

# ----------------------------------------------------------------
#  Generated mesh (keep the dictionaries that define it)
# ----------------------------------------------------------------
# Everything in polyMesh is generated by blockMesh / snappyHexMesh,
# except blockMeshDict when it lives here instead of in system/.
**/constant/polyMesh/*
!**/constant/polyMesh/blockMeshDict
# Feature/edge meshes produced by surfaceFeatures etc.
**/constant/extendedFeatureEdgeMesh/
**/constant/triSurface/*.eMesh
# Input geometry (constant/triSurface/*.stl, *.obj) is KEPT by default.
# If those are large and you regenerate them, uncomment:
# **/constant/triSurface/*.stl

# ----------------------------------------------------------------
#  Editor / OS cruft
# ----------------------------------------------------------------
*~
.*.swp
.*.swo
.DS_Store
Thumbs.db
.vscode/
.idea/

# ----------------------------------------------------------------
#  Python helpers (only relevant if any live in this repo)
# ----------------------------------------------------------------
__pycache__/
*.pyc
.ipynb_checkpoints/